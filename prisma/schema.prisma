datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  SUPER_ADMIN
  BLOG_CREATOR
  PUBLIC_VIEWER
}

model User {
  id            String    @id @default(cuid())
  username      String?   @unique
  email         String?   @unique
  emailVerified DateTime?
  passwordHash  String?
  avatarUrl     String?
  bio           String?
  role          Role      @default(PUBLIC_VIEWER)
  createdAt     DateTime  @default(now())

  posts         Post[]
  accounts      Account[]
  sessions      Session[]
  comments      Comment[]
  likes         Like[]
}

model Post {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  content     String   @db.Text
  excerpt     String?
  coverImage  String?
  published   Boolean  @default(false)
  authorId    String?
  categoryId  String?
  viewCount   Int      @default(0)
  likeCount   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  author      User?     @relation(fields: [authorId], references: [id], onDelete: SetNull)
  category    Category? @relation(fields: [categoryId], references: [id])
  comments    Comment[]
  likes       Like[]
  views       PostView[]

  @@index([authorId])
  @@index([categoryId])
}

model Comment {
  id        String   @id @default(cuid())
  content   String   @db.Text
  name      String?  
  email     String?
  postId    String
  userId    String?
  createdAt DateTime @default(now())

  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model Category {
  id    String @id @default(cuid())
  name  String
  slug  String @unique
  posts Post[]
}

model EmailVerification {
  token     String   @unique
  userId    String
  expiresAt DateTime
  used      Boolean  @default(false)
  id        String   @id @default(uuid())
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String? @db.Text
  access_token       String? @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Like {
  id                String   @id @default(cuid())
  postId            String
  userIdFingerprint String?  @map("userId")
  fingerprint       String?
  createdAt         DateTime @default(now())

  post Post  @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userIdFingerprint], references: [id], onDelete: Cascade)
}

model PostView {
  id             String   @id @default(cuid())
  postId         String
  ipFingerprint  String   @map("ip")
  createdAt      DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
}
