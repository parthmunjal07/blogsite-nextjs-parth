# Database Configuration
DATABASE_URL="postgresql://user:password@localhost:5432/blogsite"

# Authentication Secrets
# You can generate secrets using: openssl rand -base64 32
JWT_SECRET="your-jwt-secret"
AUTH_SECRET="your-auth-secret"

# UploadThing (File Uploads) - Optional for local dev if not uploading files
# UPLOADTHING_SECRET="your-uploadthing-secret"
# UPLOADTHING_APP_ID="your-uploadthing-app-id"

# Resend (Transactional Emails) - Optional for local dev
# RESEND_API_KEY="your-resend-api-key"
